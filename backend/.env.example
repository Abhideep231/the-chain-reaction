# Project metadata
APP_NAME="The Chain Reaction API"
API_VERSION=0.1.0
ENVIRONMENT=development

# CORS — comma-separated list is NOT supported; use a JSON array string
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Logging
LOG_LEVEL=INFO

# External services (required for chat/upload — leave blank for local dev
# without those features; the app logs a startup warning if unset)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_MAX_TOKENS=1000
CLAUDE_TEMPERATURE=0

# Storage
VECTOR_DB_PATH=./data/chromadb
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=25

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
